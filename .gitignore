# python
__pycache__/
*.pyc
.venv/

# os
.DS_Store

# caches / transient
**/cache/
*.zip
*.rdb
*.log

# conversations mirror — local aggregation/search ONLY.
# transcripts contain real secrets (tokens printed to logs); never push.
conversations/

# projects/ = symlinks to real repos (each has its own git). Local-only.
# keep the tracked index.md; ignore everything else (the symlinks).
/projects/*
!/projects/index.md

# secrets — never commit
.env
*.key
*_rsa
*_ed25519
